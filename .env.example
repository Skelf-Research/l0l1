# l0l1 Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# AI Provider Configuration (Required - at least one)
# =============================================================================
OPENAI_API_KEY=sk-your-openai-api-key
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# AI Provider Selection (openai or anthropic)
L0L1_AI_PROVIDER=openai

# Model Configuration
L0L1_COMPLETION_MODEL=gpt-4o-mini
L0L1_EMBEDDING_MODEL=text-embedding-3-small

# =============================================================================
# Database Configuration
# =============================================================================
DATABASE_URL=sqlite:///./data/l0l1.db
# For PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/l0l1

# =============================================================================
# Redis Configuration (for background tasks)
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# API Server Configuration
# =============================================================================
L0L1_API_HOST=0.0.0.0
L0L1_API_PORT=8000

# API URL for Jupyter/external clients
L0L1_API_URL=http://localhost:8000

# CORS Configuration (comma-separated list of allowed origins)
L0L1_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# =============================================================================
# Feature Flags
# =============================================================================
L0L1_ENABLE_PII_DETECTION=true
L0L1_ENABLE_LEARNING=true
L0L1_LEARNING_THRESHOLD=0.8

# =============================================================================
# Storage Paths
# =============================================================================
L0L1_WORKSPACE_DIR=./workspaces
L0L1_VECTOR_DB_PATH=./data/vector
L0L1_KNOWLEDGE_GRAPH_PATH=./data/kg

# =============================================================================
# Logging
# =============================================================================
L0L1_LOG_LEVEL=INFO
